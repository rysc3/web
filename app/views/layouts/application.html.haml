!!!
%html
  %head


    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}
    %meta{:charset => "utf-8"}
    %meta{:content => "IE=edge", "http-equiv" => "X-UA-Compatible"}
    %meta{:content => "width=device-width, initial-scale=1", :name => "viewport"}

    %title= @page_title
    = csrf_meta_tags
    = csp_meta_tag
    %meta{:content => @page_title || "Ryan Scherbarth", :property => "og:title"}
    %meta{:content => @og_description || "Ryan Scherbarth — Sr. Software Engineer, ML & HPC Infra at Tesla.", :property => "og:description"}
    %meta{:content => asset_url(@og_image || 'Profile-05.jpg'), :property => "og:image"}
    %meta{:content => "Ryan Scherbarth", :name => "author"}
    %meta{:content => "website", :property => "og:type"}
    %meta{:content => "ryan, ryan scherbarth, scherbarth, ry, UNM, University of New Mexico, New Mexico, Sandia Labs, Sandia, SNL, National Lab, National Labs, Center for Advanced Research Computing, student, computer science, cs, intern, internship, software engineer, SWE, Solutions Architect, engineer, bachelors, masters, cyber security, HPC, high performance computing, super computers, super computer, supercomputer, supercomputing, ML, machine learning, tesla, FSD, full self driving, tesla full self driving, tesla auto pilot, tesla autopilot, autopilot", :name => "keywords"}
    %link{rel: "icon", type: "image/png", href: asset_path("WORLD-fav.png")}

    = stylesheet_link_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css', media: 'all'
    = stylesheet_link_tag 'https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css', media: 'all'
    = stylesheet_link_tag 'application', media: 'all', 'data-turbo-track': 'reload'

  %body
    %nav.navbar.fixed-top.navbar-glass
      .container-fluid
        %a.navbar-brand{:href => "/"}
          %a.custom-link{:href => "/"} Ryan Scherbarth

    .content.flex-grow-1
      %div.pt-4
        = yield

    %hr

    %footer.footer
      .container
        .row.justify-content-center
          .col-md-12.d-flex.justify-content-center
            %ul.favicon-list.list-inline
              %li.favicon-item.list-inline-item
                %a{:href => "https://www.linkedin.com/in/ryanscherbarth/", :target => "_blank"}
                  %i.fab.fa-linkedin
              %li.favicon-item.list-inline-item
                %a{:href => "https://github.com/rysc3", :target => "_blank"}
                  %i.fab.fa-github
              %li.favicon-item.list-inline-item
                %a{:href => "https://stackoverflow.com/users/20306478/ry-sch", :target => "_blank"}
                  %i.fab.fa-stack-overflow
              %li.favicon-item.list-inline-item
                %a{:href => "mailto:online@ryanscherbarth.com"}
                  %i.fas.fa-envelope

= javascript_include_tag 'application1', 'data-turbo-track': 'reload'
= javascript_include_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js', defer: true
