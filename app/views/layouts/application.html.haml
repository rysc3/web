= javascript_include_tag 'application1', 'data-turbo-track': 'reload'
= javascript_include_tag 'https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js', defer: true
:javascript
  // Cursor glow
  (function() {
    var glow = document.getElementById('cursor-glow');
    if (!glow) return;
    document.addEventListener('mousemove', function(e) {
      glow.style.left = e.clientX + 'px';
      glow.style.top  = e.clientY + 'px';
      glow.style.opacity = '1';
    }, { passive: true });
    document.addEventListener('mouseleave', function() {
      glow.style.opacity = '0';
    });
  })();

  // Page transitions
  (function() {
    var content = document.querySelector('.content');
    document.addEventListener('click', function(e) {
      var link = e.target.closest('a[href]');
      if (!link) return;
      var href = link.getAttribute('href');
      if (!href || href.startsWith('#') || href.startsWith('http') ||
          href.startsWith('mailto') || href.startsWith('//') ||
          link.target === '_blank' || link.hasAttribute('download')) return;
      e.preventDefault();
      if (content) content.classList.add('page-leaving');
      setTimeout(function() { window.location = href; }, 210);
    });
  })();

  // Scroll progress bar
  (function() {
    var bar = document.getElementById('scroll-progress');
    if (!bar) return;
    window.addEventListener('scroll', function() {
      var scrollTop = window.scrollY || document.documentElement.scrollTop;
      var docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      bar.style.width = (docHeight > 0 ? (scrollTop / docHeight) * 100 : 0) + '%';
    }, { passive: true });
  })();

  // Starfield
  (function() {
    var canvas = document.getElementById('starfield');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize, { passive: true });

    // Static stars — spread across 3x viewport height so scrolling feels deep
    var STAR_COUNT = 175;
    var stars = Array.from({ length: STAR_COUNT }, function() {
      return {
        x: Math.random(),
        y: Math.random(),
        r: Math.random() * 1.3 + 0.2,
        base: Math.random() * 0.45 + 0.1,
        phase: Math.random() * Math.PI * 2,
        freq: Math.random() * 0.45 + 0.1  // slow twinkle, wide range so each star feels unique
      };
    });

    // Shooting stars queue
    var shoots = [];

    function spawnShoot() {
      var angle = (Math.random() * 35 + 10) * Math.PI / 180;
      shoots.push({
        x: Math.random() * canvas.width * 0.85,
        y: Math.random() * canvas.height * 0.5,
        vx: Math.cos(angle) * 440,
        vy: Math.sin(angle) * 440,
        len: Math.random() * 100 + 60,
        life: 1.0
      });
    }

    // Two independent schedulers — doubles the rate
    function scheduleShoot() {
      setTimeout(function() {
        spawnShoot();
        // small chance of a quick double
        if (Math.random() < 0.25) setTimeout(spawnShoot, Math.random() * 400 + 100);
        scheduleShoot();
      }, Math.random() * 4600 + 2600);
    }
    scheduleShoot();
    setTimeout(scheduleShoot, Math.random() * 2600 + 1300); // offset second scheduler

    var last = 0;
    function frame(ts) {
      var dt = Math.min((ts - last) / 1000, 0.05);
      last = ts;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var t = ts / 1000;

      // Draw stars
      stars.forEach(function(s) {
        var op = s.base + Math.sin(t * s.freq + s.phase) * 0.28;  // bigger twinkle swing
        op = Math.max(0.02, Math.min(0.95, op));
        ctx.beginPath();
        ctx.arc(s.x * canvas.width, s.y * canvas.height, s.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,' + op + ')';
        ctx.fill();
      });

      // Draw shooting stars
      shoots = shoots.filter(function(s) {
        s.life -= dt * 1.4;
        if (s.life <= 0) return false;
        s.x += s.vx * dt;
        s.y += s.vy * dt;
        var tailX = s.x - s.vx * (s.len / 420);
        var tailY = s.y - s.vy * (s.len / 420);
        var grad = ctx.createLinearGradient(s.x, s.y, tailX, tailY);
        grad.addColorStop(0, 'rgba(255,255,255,' + (s.life * 0.9).toFixed(2) + ')');
        grad.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.beginPath();
        ctx.moveTo(s.x, s.y);
        ctx.lineTo(tailX, tailY);
        ctx.strokeStyle = grad;
        ctx.lineWidth = 1.5;
        ctx.stroke();
        return true;
      });

      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  })();
