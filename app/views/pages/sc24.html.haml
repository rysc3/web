.sc-hero
  .sc-hero-logo
    %img{src: asset_path('sc24_logo_2.png'), alt: 'SC24'}
  .sc-hero-body
    %p.sc-hero-sub HPC Student Cluster Competition
    %p.sc-hero-meta Atlanta, GA · November 2024
    .sc-hero-links
      %a.sc-hero-link{href: "https://carc.unm.edu/news--events/News/sc24.html", target: "_blank"}
        %i.fas.fa-external-link-alt
        SC24 CARC Team Article
      %a.sc-hero-link{href: "https://sc24.supercomputing.org/2024/09/teams-compete-in-the-ultimate-hpc-challenge-at-sc24/", target: "_blank"}
        %i.fas.fa-external-link-alt
        SCC24 Meet the Teams
      %a.sc-hero-link{href: "https://sc24.supercomputing.org/students/student-cluster-competition/", target: "_blank"}
