!!!
%html{lang: "en"}
  -# Google tag (gtag.js)
  %script{async: "", src: "https://www.googletagmanager.com/gtag/js?id=G-7VD1T7W41S"}
  :javascript
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-7VD1T7W41S');
  %head
    %meta{content: "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %meta{charset: "utf-8"}/
    %meta{content: "width=device-width, initial-scale=1, shrink-to-fit=no", name: "viewport"}/
    %title Portfolio
    %link{href: "assets/favicon.ico", rel: "icon", type: "image/x-icon"}/
    / Google fonts
    %link{href: "https://fonts.googleapis.com/css?family=Raleway:100,100i,200,200i,300,300i,400,400i,500,500i,600,600i,700,700i,800,800i,900,900i", rel: "stylesheet"}/
    %link{href: "https://fonts.googleapis.com/css?family=Lora:400,400i,700,700i", rel: "stylesheet"}/
    %link{href: asset_path('styles.css'), rel: 'stylesheet'}/
  %body 

  .container
    #accordion
      .card
        .card-header
          %a.collapsed.btn{"data-bs-toggle" => "collapse", href: "#collapseOne"}
            Collapsible Group Item #1
        #collapseOne.collapse{"data-bs-parent" => "#accordion"}
          .card-body
            Lorem ipsum..
      .card
        .card-header
          %a.collapsed.btn{"data-bs-toggle" => "collapse", href: "#collapseTwo"}
            Collapsible Group Item #2
        #collapseTwo.collapse{"data-bs-parent" => "#accordion"}
          .card-body
            Lorem ipsum..
      .card
        .card-header
          %a.collapsed.btn{"data-bs-toggle" => "collapse", href: "#collapseThree"}
            Collapsible Group Item #3
        #collapseThree.collapse{"data-bs-parent" => "#accordion"}
          .card-body
            Lorem ipsum..

  .container.border.rounded.p-3
    .row
      .col-md-4
        #list-example.list-group
          - @docs.each do |doc|
            %a.list-group-item.list-group-item-action{href: "#list-item-1"}= doc.title
      .col-md-8.pr-0
        .scrollspy-example{"data-bs-smooth-scroll" => "true", "data-bs-spy" => "scroll", "data-bs-target" => "#list-example", tabindex: "0"}
          - @docs.each do |doc|
            = link_to doc_path(doc) do
              %h4#list-item-1= doc.title
            %p= doc.content